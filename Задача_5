#Задача 5круговые диаграммы, а также точечные графики с помощью пакета
#Matplotlib.
#Сформировать и отобразить данные в виде трех разных графиков:
#- из п. 1 – в виде столбчатой и круговой диаграммы (два графика);
#- из п. 2 – в виде множества точек на плоскости (один график)

import matplotlib.pyplot as plt
import numpy as np

cities = ['Москва', 'Санкт-Петербург', 'Пермь', 'Казань', 'Екатеринбург']
popularity = [1500, 1200, 700, 600, 500]

# Столбчатая диаграмма
plt.figure(figsize=(10, 6))  # Создаём фигуру (канву) для графика с размером 10x6 дюймов. figsize задаёт размеры фигуры.
plt.bar(cities, popularity, color='skyblue')  # Рисуем столбчатую диаграмму:
# - cities — категории (ось X);
# - popularity — значения (ось Y);
plt.title('Туристическая популярность городов России', fontsize=16)  # Добавляем заголовок графика с размером шрифта 16.
plt.xlabel('Города', fontsize=12)  # Добавляем подпись к оси X (города) с размером шрифта 12.
plt.ylabel('Количество туристов (тыс.)', fontsize=12)  # Добавляем подпись к оси Y (количество туристов) с размером шрифта 12.
# - axis='y' — сетка только по вертикальной оси;
# - linestyle='--' — стиль линии сетки (пунктир);
# - alpha=0.7 — прозрачность сетки (70%).
plt.show()  # Отображаем график.

# Круговая диаграмма
plt.figure(figsize=(8, 8))  # Создаём новую фигуру для круговой диаграммы, размером 8x8 дюймов (квадрат для симметрии круга).
plt.pie(popularity, labels=cities, autopct='%1.1f%%', colors=plt.cm.Set3.colors)  # Рисуем круговую диаграмму:
# - popularity — значения долей для каждого сектора;
# - labels=cities — подписи секторов (названия городов);
# - autopct='%1.1f%%' — формат отображения процентов в каждом секторе (1 знак после запятой);
# - startangle=90 — начальный угол диаграммы (90 градусов, чтобы начать с верхней части круга);
# - colors=plt.cm.Set3.colors — используем цветовую палитру Set3 из matplotlib для раскраски секторов.
plt.title('Доля туристической популярности городов', fontsize=16)  # Добавляем заголовок круговой диаграммы.
plt.show()  # Отображаем круговую диаграмму.

# Генерируем случайные точки
np.random.seed(42)  # Устанавливаем «семя» (seed) генератора случайных чисел (42 — произвольное число). Это делает результаты воспроизводимыми — при каждом запуске будут одни и те же случайные числа.
x_coords = np.random.uniform(-5.2, 20.7, 1200)  # Генерируем 1200 случайных чисел для координаты X в диапазоне от -5.2 до 20.7 с равномерным распределением. Результат сохраняется в массиве x_coords.
y_coords = np.random.uniform(-5.2, 20.7, 1200)  # Аналогично генерируем 1200 случайных чисел для координаты Y в том же диапазоне. Результат сохраняется в массиве y_coords.

# Точечный график
plt.figure(figsize=(10, 8))  # Создаём фигуру для точечного графика размером 10x8 дюймов.
plt.scatter(x_coords, y_coords, c='red', edgecolors='blue')  # Рисуем точечный график (scatter plot):
# - x_coords — координаты точек по оси X;
# - y_coords — координаты точек по оси Y;
# - s=10 — размер точек (в точках²);
# - c='darkorange' — цвет точек (тёмно-оранжевый);
# - edgecolors='black' — цвет контура точек (чёрный).
plt.title('Случайное распределение 1200 точек на плоскости', fontsize=16)  # Добавляем заголовок для точечного графика.
plt.xlabel('Координата X', fontsize=12)  # Добавляем подпись к оси X.
plt.ylabel('Координата Y', fontsize=12)  # Добавляем подпись к оси Y.
