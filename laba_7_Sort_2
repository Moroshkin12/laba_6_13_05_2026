#неотсортированной с помощью символа |. Протокол сортировки выводить в текстовый
#файл

def bubble_sort(arr, filename):
    n = len(arr)

    with open(filename, 'w') as f:
        for i in range(n):
            flag = False


            for j in range(0, n - i - 1):
                if arr[j] > arr[j + 1]:
                    arr[j], arr[j + 1] = arr[j + 1], arr[j]
                    flag = True

            unsorted_part = arr[:n - i - 1]  # на 1 элемент меньше
            sorted_part = arr[n - i - 1:]  # на 1 элемент больше


            unsorted_str = " ".join([str(x) for x in unsorted_part])
            sorted_str = " ".join([str(x) for x in sorted_part])


            log_line = f"Шаг {i + 1}: {unsorted_str} | {sorted_str}"
            print(log_line)


            f.write(log_line + '\n')


            if not flag:
                break

    return arr

