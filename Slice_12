#Slice12.
#1. Создайте с помощью NumPy массив A размера 6×86×8, заполненный
#числами от 0 до 47 (включительно) построчно (т.е. A[0, :] = [0, 1, ..., 7],
#A[1, :] = [8, 9, ..., 15] и т.д.).
#2. Затем с помощью только операций среза (без циклов, индексных
#массивов или логических масок) извлеките из A следующие подмассивы и
#сохраните их в отдельные переменные:
#B — подматрица размера 3×43×4, состоящая из элементов из чётных
#строк (0, 2, 4) и нечётных столбцов (1, 3, 5, 7).
#C — последний столбец массива A, представленный как одномерный
#вектор длины 6.
#D — "шахматный фрагмент": каждая вторая строка, начиная с первой
#(1, 3, 5), и в каждой из них — каждая вторая колонка, начиная с
#нулевой (0, 2, 4, 6). Результат — массив размера 3×43×4.
#4
#E — центральный блок массива A размера 2×42×4: строки 2–3
#(включительно), столбцы 2–5 (включительно).
#Выведите все полученные массивы на экран. Убедитесь, что они совпадают с
#ожидаемыми значениями

import numpy as np

array_A = np.arange(48).reshape(6, 8)
array_B = array_A[::2, 1::2]
# Пояснение:
# ::2 для строк — берём каждую вторую строку, начиная с индекса 0 (строки 0, 2, 4);
# 1::2 для столбцов — берём каждую вторую колонку, начиная с индекса 1 (столбцы 1, 3, 5, 7).
array_C = array_A[:, -1]
# Пояснение:
# : для строк — берём все строки;
# -1 для столбцов — берём последний столбец (индекс -1 соответствует последнему элементу).
array_D = array_A[1::2, ::2]
# Пояснение:
# 1::2 для строк — берём каждую вторую строку, начиная с индекса 1 (строки 1, 3, 5);
# ::2 для столбцов — берём каждую вторую колонку, начиная с индекса 0 (столбцы 0, 2, 4, 6).
array_E = array_A[2:4, 2:6]
# Пояснение:
# 2:4 для строк — берём строки с индексами 2 и 3 (верхняя граница 4 не включается);
# 2:6 для столбцов — берём столбцы с индексами 2, 3, 4 и 5 (верхняя граница 6 не включается).

print("Исходный массив A (6×8):")
print(array_A)
print("\nB (3×4, чётные строки и нечётные столбцы):")
print(array_B)
print("\nC (последний столбец, вектор длины 6):")
print(array_C)
print("\nD (3×4, «шахматный» фрагмент):")
print(array_D)
print("\nE (2×4, центральный блок):")
print(array_E)
