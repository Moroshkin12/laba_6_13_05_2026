#Задача 3. Напишите программу для решения СЛАУ с использованием
#библиотеки NumPy. Результат решения вывести в виде вектора. Сделать
#проверку.

import numpy as np

A = np.array([
    [1, -1, 1],
    [1, 1, -1],
    [1, 2, -1]
])

b = np.array([2, 0, 2])

answer = np.linalg.solve(A, b)

# Шаг 4. Выводим результат (вектор решения)
print("Вектор решения (x₁, x₂, x₃):", answer)

# Шаг 5. Проверка решения: подставляем найденные значения в исходную систему
# Вычисляем A * solution и сравниваем с b
check = np.dot(A, answer)
print("Проверка (A * x = b):", check)

# Сравниваем результаты с исходным вектором b
print("Совпадает с правыми частями (b):", np.allclose(check, b))
