#Matr3. Обратная матрица.
#1. Дано число n. Сгенерировать матрицу A размера n⨯n со случайными
#вещественными числами из набора {-1; 1}.
#2. Проверить существования обратной матрицы А через определитель с
#помощью функции numpy.linalg.det(А)
#(если определитель равен нулю, матрицу сгенерировать повторно).
#3. Найти обратную матрицу средствами библиотеки NumPy.
#4. Средствами NumPy выделить второй столбец и третью строку
#полученной матрицы.
#5. Вывести на экран обратную матрицу , а также второй столбец и третью
#строку на экран.


import numpy as np

def generate_matrix(n):
    """Генерируем матрицу n×n со значениями -1 и 1 вещественными"""
    while True:
        matrix = np.random.uniform(low=-1.0, high=1.0, size=(n, n))
        matrix = np.round(matrix, 4)
        determinant = np.linalg.det(matrix)
        if determinant != 0:
            return matrix


def get_determinant(matrix):
    """Возвращает определитель матрицы."""
    return np.round(np.linalg.det(matrix), 4)


def compute_inverse(matrix):
    """Вычисляет обратную матрицу."""
    try:
        inverse = np.linalg.inv(matrix)
        return np.round(inverse, 4)
    except np.linalg.LinAlgError:
        print("Ошибка: матрица необратима!")
        return None

def second_column(matrix):
    """Извлекает второй столбец срезом (индекс 1)"""
    if matrix.shape[1] >= 2:
        return matrix[:, 1]
    else:
        print("Ошибка: в матрице меньше 2 столбцов!")
        return None

def third_row(matrix):
    """Извлекает третью строку срезом (индекс 2)"""
    if matrix.shape[0] >= 3:  #
        return matrix[2, :]
    else:
        print("Ошибка: в матрице меньше 3 строк!")
        return None

def print_array_without_brackets(array):
    """Выводит массив NumPy без скобок, используя цикл for"""
    for element in array:
        print(f"{element:8.4f}", end=" ")
    print()  # переход на новую строку

def display_results(inverse_matrix, second_column, third_row,n):
    """Выводит результаты на экран без скобок."""
    print("\n" + "=" * 50)
    print("РЕЗУЛЬТАТЫ:")
    print("=" * 50)

    if inverse_matrix is not None:
        print("\n1. Обратная матрица A⁻¹:")
        for i in range(n):
            for j in range(n):
                print(str(inverse_matrix[i, j]), end=" ")
            print( )



        if second_column is not None:
            print("\n2. Второй столбец обратной матрицы:")
            print_array_without_brackets(second_column)
        else:
            print("\n2. Второй столбец: не доступен (матрица слишком маленькая)")

        if third_row is not None:
            print("\n3. Третья строка обратной матрицы:")
            print_array_without_brackets(third_row)
        else:
            print("\n3. Третья строка: не доступна (матрица слишком маленькая)")
    else:
        print("\nОбратная матрица не была вычислена!")

    print("\n" + "=" * 50)
    print("Программа завершена успешно!")
    print("=" * 50)

def main():
    print("=" * 50)
    print("Программа для работы с матрицами (NumPy)")
    print("=" * 50)

    np.random.seed(42)

    try:
        n = int(input("Введите размерность матрицы n (целое положительное число): "))
        if n <= 0:
            print("Ошибка: размерность должна быть положительным целым числом!")
            return

        print(f"\nШаг 1: Генерация матрицы размера {n}×{n}")
        matrix_a = generate_matrix(n)
        print("Матрица успешно сгенерирована:")
        for i in range(n):
            for j in range(n):
                print(str(matrix_a[i, j]), end=" ")
            print()

        det_a = get_determinant(matrix_a)
        print(f"\nШаг 2: Определитель матрицы: {det_a}")
        print("Матрица обратима (определитель не равен нулю).")

        print("\nШаг 3: Вычисление обратной матрицы")
        matrix_a_inv = compute_inverse(matrix_a)

        if matrix_a_inv is not None:
            print("Обратная матрица успешно найдена.")

            print("\nШаг 4: Извлечение данных из обратной матрицы...")
            second_col = second_column(matrix_a_inv)
            third_row_val = third_row(matrix_a_inv)  # переименовал переменную, чтобы избежать конфликта с функцией

            display_results(matrix_a_inv, second_col, third_row_val,n)
        else:
            print("Не удалось вычислить обратную матрицу!")

    except ValueError:
        print("Ошибка: введите целое число!")
    except Exception as e:
        print(f"Произошла непредвиденная ошибка: {e}")

if __name__ == "__main__":
    main()

